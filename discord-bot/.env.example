# ===========================================
# CONFIGURATION DU BOT DISCORD
# ===========================================

# Token du bot (Discord Developer Portal > Bot > Token)
DISCORD_TOKEN=

# Client ID de l'application (Discord Developer Portal > General Information > Application ID)
CLIENT_ID=1520172382617338006

# ID du serveur Discord (clic droit sur le serveur > Copier l'identifiant)
# Utilisé pour déployer les commandes slash rapidement sur un seul serveur (dev)
# Laisse vide pour déployer les commandes globalement (peut prendre jusqu'à 1h pour apparaître)
GUILD_ID=993478944990965830

# ===========================================
# SYSTÈME DE TICKETS
# ===========================================

# ID du salon où sera envoyé le panel de création de ticket
TICKET_PANEL_CHANNEL_ID=1520180438692270101

# ID de la catégorie où seront créés les tickets
TICKET_CATEGORY_ID=1520180707312537641
TICKET_CATEGORY_PARTENARIAT_ID=1520385785705009173
TICKET_CATEGORY_RECRUTEMENT_ID=1520385270468579358
TICKET_CATEGORY_RECOMPENSES_ID=1520385921105789040

# ID(s) des rôles staff qui peuvent voir/gérer les tickets (séparés par une virgule)
TICKET_STAFF_ROLE_IDS=1520180647635718255

# ===========================================
# VÉRIFICATION (CAPTCHA)
# ===========================================

# ID du salon où sera envoyé le panel de vérification
VERIFY_PANEL_CHANNEL_ID=1520180826162204803

# ID du rôle "Non vérifié" donné automatiquement à l'arrivée (optionnel)
UNVERIFIED_ROLE_ID=1520180887185133738

# ID du rôle donné automatiquement après réussite du captcha
VERIFIED_ROLE_ID=994616918713569331

# ===========================================
# ACCUEIL (BIENVENUE / DÉPART)
# ===========================================

# ID du salon pour les messages de bienvenue
WELCOME_CHANNEL_ID=993478944990965833

# ID du salon pour les messages de départ
LEAVE_CHANNEL_ID=1520181114541441095

# ===========================================
# NOTIFICATION TWITCH LIVE
# ===========================================

# Crée une app sur https://dev.twitch.tv/console/apps pour obtenir ces identifiants
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Pseudo(s) Twitch à surveiller, séparés par une virgule (ex: ninja,zerator)
TWITCH_STREAMERS=

# ID du salon où envoyer la notification de live
TWITCH_ANNOUNCE_CHANNEL_ID=

# ID du rôle à ping lors d'un live (optionnel, laisser vide pour aucun ping)
TWITCH_PING_ROLE_ID=

# Intervalle de vérification en secondes (60 par défaut, minimum recommandé 60)
TWITCH_CHECK_INTERVAL=60
